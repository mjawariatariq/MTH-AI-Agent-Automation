"""
Same question, different personalities!
"""

class PersonaAgent:
    def __init__(self, role):
        self.role = role
        self.personas = {
            "support": {
                "role": "Professional Customer Support Executive",
                "tone": "Polite, helpful, solution-oriented",
                "style": "Professional and empathetic",
                "constraints": "Always offer solutions, never blame customer"
            },
            "teacher": {
                "role": "Patient University Professor",
                "tone": "Educational, clear, encouraging",
                "style": "Explains concepts with examples",
                "constraints": "No jargon, use simple language, keep it under 100 words"
            },
            "ceo": {
                "role": "Innovative Tech CEO",
                "tone": "Visionary, confident, inspiring",
                "style": "Big picture thinking, strategic",
                "constraints": "Focus on innovation and market impact"
            }
        }
    
    def respond(self, question):
        persona = self.personas[self.role]
        
        print("\n" + "="*50)
        print(f" ROLE: {persona['role']}")
        print(f" TONE: {persona['tone']}")
        print(f" CONSTRAINTS: {persona['constraints']}")
        print("-"*50)
        
# Simulated responses based on persona
        responses = {
            "support": [
                "Thank you for reaching out! I understand your concern. Let me help you resolve this issue step by step.",
                "I apologize for the inconvenience. Here's what I can do to assist you...",
                "Great question! Let me find the best solution for you. Can you please share more details?"
            ],
            "teacher": [
                "Let me explain this in simple terms. Imagine you're learning to ride a bicycle...",
                "That's an excellent question! Let's break it down into smaller parts...",
                "I love how curious you are! Here's an analogy to help you understand..."
            ],
            "ceo": [
                "This is exactly the kind of innovative thinking we need! The market is changing...",
                "Vision is everything. Let me share how we're approaching this from a strategic angle...",
                "Disruption is the name of the game. Here's our bold vision for this..."
            ]
        }
        
        response = responses[self.role][0]
        print(f" Q: {question}")
        print(f" A: {response}")
        return response

# RUN DEMO
print("PERSONA PATTERN DEMO - Same Question, Different Personalities")
print("="*60)

question = "How do you handle customer complaints?"

roles = ["support", "teacher", "ceo"]

for role in roles:
    agent = PersonaAgent(role)
    agent.respond(question)
    print("-"*40)

print("\n KEY TAKEAWAY: Persona AI ke responses ko professional aur consistent banata hai!")
